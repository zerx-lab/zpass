# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts
.task/
# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# Generated native folders
/ios

# Android: track source/config, ignore only build artifacts and sensitive keystores.
# (debug.keystore is intentionally tracked so APK signature stays stable across machines.)
/android/build/
/android/.gradle/
/android/.kotlin/
/android/.cxx/
/android/local.properties
/android/app/build/
/android/app/.cxx/
/android/app/release/
/android/app/*.keystore
!/android/app/debug.keystore

# 本地 Expo Module 的 Android Gradle 产物（源码保留，编译输出不入 git）
modules/*/android/build/
modules/*/android/.gradle/
modules/*/android/.cxx/
