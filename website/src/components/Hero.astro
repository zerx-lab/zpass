---
// ============================================================================
// Hero — 主视觉（1Password 风格）
//
// 设计语言：
//   - 居中布局，巨型轻字重标题（H1 ~96px，font-weight 300）
//   - 米色 eyebrow tag（不再用蓝点 + mono）
//   - 双 CTA：主蓝色实底 + 描边
//   - 4 列统计行，超轻字重数字
//   - 默认 ink 暗色背景，搭配底部蓝色渐变
//
// 注：保留原有的 hero-stats 数据契约（4 项），保留 hero_eyebrow / hero_title_1
// / hero_title_2 / hero_sub / hero_cta_primary / hero_availability 等 i18n
// 字段，文案完全不变。
// ============================================================================

import type { SiteStrings, Locale } from "../i18n/strings";
import { APP_REGISTER_URL } from "../i18n/strings";

export interface Props {
	t: SiteStrings;
	locale: Locale;
	/** 当前语言版本的首页基础路径，用于锚点链接 */
	homeBase?: string;
}

const { t, locale, homeBase = locale === "zh" ? "/zh/" : "/" } = Astro.props;

const stats = [
	{ n: t.hero_stat_1_n, l: t.hero_stat_1_l },
	{ n: t.hero_stat_2_n, l: t.hero_stat_2_l },
	{ n: t.hero_stat_3_n, l: t.hero_stat_3_l },
	{ n: t.hero_stat_4_n, l: t.hero_stat_4_l },
];
---

<section class="hero hero--ink" id="top">
	<div class="hero-grid-bg"></div>
	<div class="wrap">
		<div class="eyebrow">
			<span class="dot"></span>{t.hero_eyebrow}
		</div>

		<h1>
			<span>{t.hero_title_1}</span>
			{" "}
			<span class="dim">{t.hero_title_2}</span>
		</h1>

		<p class="lede">{t.hero_sub}</p>

		<div class="hero-cta">
			<a href={`${homeBase}#download`} class="btn primary"
				>{t.hero_cta_primary} <span class="arrow">→</span></a
			>
			<a href={APP_REGISTER_URL} class="btn">{t.nav_register}</a>
			<a href={`${homeBase}#features`} class="btn">{t.nav_features}</a>
		</div>

		<div class="hero-availability mono">{t.hero_availability}</div>

		<!-- ========== Hero 统计数字行 ========== -->
		<div class="hero-stats">
			{
				stats.map((s) => (
					<div>
						<div class="n">{s.n}</div>
						<div class="l">{s.l}</div>
					</div>
				))
			}
		</div>
	</div>
</section>
