---
// ============================================================================
// Pricing — 定价方案
// 套餐数据来自 zpass_cloud 公开端点（与 SaaS 运营平台同源 plans 表），由页面
// SSR 时通过 pricing-fetcher 拉取并映射成 PricingTier[]，作为 `tiers` 传入。
// 后端不可达时 pricing-fetcher 降级到内置 i18n 文案，组件无需感知。
//
// 居中的推荐档使用 .featured 高亮样式（带 accent 边框 + 阴影）；
// 联系销售档（contact）渲染为打开商务联系弹窗的按钮，而非下单链接。
// ============================================================================

import type { SiteStrings } from "../i18n/strings";
import { APP_REGISTER_URL } from "../i18n/strings";
import type { PricingTier } from "../lib/pricing-fetcher";

export interface Props {
	t: SiteStrings;
	/** 由页面 SSR 拉取并映射的套餐档（与运营平台同源）。 */
	tiers: PricingTier[];
	/** 章节背景变体 */
	variant?: "default" | "soft" | "ink" | "blue";
}

const { t, tiers, variant = "default" } = Astro.props;
const sectionClass =
	variant === "default" ? "section" : `section section--${variant}`;

// 对比表：仅在所有档都带后端结构化 compare 时渲染（降级态 compare 为空对象则隐藏）。
const COMPARE_ROW_KEYS = [
	"price_yearly",
	"max_members",
	"max_vaults",
	"max_items",
	"max_guests",
	"storage",
	"trial",
	"advanced_mfa",
	"family_sharing",
	"audit_log",
	"sso",
	"scim",
] as const;
const showCompare =
	tiers.length > 0 && tiers.every((tier) => Object.keys(tier.compare).length > 0);
---

<section class={sectionClass} id="pricing">
	<div class="wrap">
		<div class="sec-head reveal">
			<div class="index mono"><b>07</b> / {t.section_pricing}</div>
			<div>
				<h2>{t.section_pricing}</h2>
				<div class="sec-sub">{t.section_pricing_sub}</div>
			</div>
		</div>

		<div class="pricing-grid">
			{
				tiers.map((tier) => (
					<div
						class={"price-card reveal" + (tier.featured ? " featured" : "")}
						data-plan={tier.plan}
					>
						<div class="name mono">{tier.name}</div>
						<div class="price">{tier.price}</div>
						<div class="unit">{tier.unit}</div>

						<ul>
							{tier.bullets.map((b) => (
								<li>{b}</li>
							))}
						</ul>

						{tier.contact ? (
							<button
								class="btn"
								data-contact-open="business"
							>
								{tier.cta} <span class="arrow">→</span>
							</button>
						) : (
							<a
								href={APP_REGISTER_URL}
								class={"btn" + (tier.featured ? " primary" : "")}
							>
								{tier.cta} <span class="arrow">→</span>
							</a>
						)}
					</div>
				))
			}
		</div>

		{showCompare && (
			<div class="compare reveal">
				<h3 class="compare-title mono">{t.pricing_compare_title}</h3>
				<div class="compare-scroll">
					<table class="compare-table">
						<thead>
							<tr>
								<th class="compare-dim" />
								{tiers.map((tier) => (
									<th class={tier.featured ? "featured" : ""}>{tier.name}</th>
								))}
							</tr>
						</thead>
						<tbody>
							{COMPARE_ROW_KEYS.map((key) => (
								<tr>
									<th scope="row" class="compare-dim">
										{t.pricing_compare_rows[key]}
									</th>
									{tiers.map((tier) => {
										const cell = tier.compare[key];
										return (
											<td class={tier.featured ? "featured" : ""}>
												{cell === true ? (
													<span class="ck" aria-label={t.pricing_compare_yes}>✓</span>
												) : cell === false ? (
													<span class="dash" aria-hidden="true">—</span>
												) : (
													cell
												)}
											</td>
										);
									})}
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</div>
		)}
	</div>
</section>
