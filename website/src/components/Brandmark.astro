---
// ============================================================================
// Brandmark — ZPass 衰线字母 "Z"（assets/logo-{light,dark}.svg 同源）
// ---------------------------------------------------------------------------
// 渲染纯 Z 字本体（无圆底），fill=currentColor，由父级通过 `color` 控制
// light/dark 主题颜色。Nav 等小尺寸 (16~32px) 场景下点阵/圆底会糊成噪点，
// 仅 Z 字本体的轮廓在 favicon / Nav / Titlebar 都最清晰。
// 大尺寸（splash、about hero）若需要圆底背景版，直接 <img src="/assets/logo-*.svg"/>
// ============================================================================

export interface Props {
	/** 渲染尺寸（像素），默认 24，按比例缩放 */
	size?: number;
	/** 附加 class，便于父级布局控制 */
	class?: string;
	/** ARIA 标签；省略则视为装饰图标 */
	ariaLabel?: string;
}

const { size = 24, class: className, ariaLabel } = Astro.props;
const role = ariaLabel ? "img" : undefined;
---

<svg
	xmlns="http://www.w3.org/2000/svg"
	viewBox="0 0 100 100"
	width={size}
	height={size}
	class={className}
	role={role}
	aria-label={ariaLabel}
	aria-hidden={ariaLabel ? undefined : "true"}
	focusable="false"
>
	<g fill="currentColor">
		<rect x="20" y="22" width="60" height="12" />
		<rect x="20" y="22" width="6" height="20" />
		<rect x="74" y="22" width="6" height="20" />
		<rect x="20" y="66" width="60" height="12" />
		<rect x="20" y="58" width="6" height="20" />
		<rect x="74" y="58" width="6" height="20" />
		<polygon points="68,34 80,34 32,66 20,66" />
	</g>
</svg>
