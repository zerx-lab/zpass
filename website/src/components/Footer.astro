---
// ============================================================================
// Footer — 站点页脚（精简版）
// 早期开发阶段，无真实可跳转目标，因此移除 Product/Resources/Company/Legal
// 四列死链与重复的构建标识，仅保留：
//   - 品牌 + 一句话 tagline
//   - 一行版权 + 开发状态
// ============================================================================

import type { SiteStrings } from "../i18n/strings";
import { GITHUB_URL } from "../i18n/strings";
import Brandmark from "./Brandmark.astro";

export interface Props {
	t: SiteStrings;
}

const { t } = Astro.props;
---

<footer class="foot foot--lite">
	<div class="wrap">
		<div class="foot-lite">
			<div class="foot-lite-brand">
				<div class="brand">
					<span class="logo"><Brandmark size={22} /></span>
					<span>ZPass</span>
				</div>
				<div class="foot-tagline">{t.footer_tagline}</div>
			</div>

			<div class="foot-lite-right">
				<div class="foot-actions">
					<a
						class="foot-github"
						href={GITHUB_URL}
						target="_blank"
						rel="noopener"
						aria-label={t.github_aria}
						title={t.github_aria}
					>
						<svg
							viewBox="0 0 24 24"
							width="14"
							height="14"
							fill="currentColor"
							aria-hidden="true"
						>
							<path
								fill-rule="evenodd"
								clip-rule="evenodd"
								d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.57.1.78-.25.78-.55v-1.94c-3.2.7-3.88-1.54-3.88-1.54-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.27-5.24-5.65 0-1.25.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.14 1.17.91-.25 1.89-.38 2.86-.39.97 0 1.95.13 2.86.39 2.18-1.48 3.14-1.17 3.14-1.17.62 1.58.23 2.75.11 3.04.73.8 1.18 1.83 1.18 3.08 0 4.39-2.7 5.36-5.27 5.64.41.36.78 1.05.78 2.12v3.14c0 .31.2.66.79.55C20.21 21.38 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"
							/>
						</svg>
						<span class="mono">GitHub</span>
					</a>
					<button class="foot-contact mono" data-contact-open>
						{t.contact_trigger}
					</button>
				</div>
				<div class="foot-lite-meta mono">
					<span>{t.footer_built}</span>
					<span aria-hidden="true">·</span>
					<span>{t.footer_oss}</span>
					<span aria-hidden="true">·</span>
					<span>{t.footer_version}</span>
				</div>
			</div>
		</div>
	</div>
</footer>

<style>
	.foot--lite {
		padding: 48px 0 40px;
	}

	.foot-lite {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 32px;
		flex-wrap: wrap;
	}

	.foot-lite-brand .foot-tagline {
		margin-top: 10px;
	}

	.foot-lite-right {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 8px;
	}

	.foot-lite-meta {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		font-size: 11px;
		color: var(--text-3);
	}

	.foot-actions {
		display: inline-flex;
		align-items: center;
		gap: 8px;
	}

	.foot-contact {
		background: none;
		border: 1px solid var(--line);
		border-radius: var(--radius-sm);
		padding: 4px 10px;
		font-size: 11px;
		color: var(--text-3);
		cursor: pointer;
		transition: color 0.15s, border-color 0.15s, background 0.15s;
		letter-spacing: 0.02em;
	}

	.foot-contact:hover {
		color: var(--text);
		border-color: var(--text-3);
		background: var(--bg-hover);
	}

	.foot-github {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 4px 10px;
		font-size: 11px;
		color: var(--text-3);
		border: 1px solid var(--line);
		border-radius: var(--radius-sm);
		text-decoration: none;
		letter-spacing: 0.02em;
		transition: color 0.15s, border-color 0.15s, background 0.15s;
	}

	.foot-github:hover {
		color: var(--text);
		border-color: var(--text-3);
		background: var(--bg-hover);
	}

	.foot-github svg {
		flex-shrink: 0;
	}

	@media (max-width: 640px) {
		.foot-lite {
			flex-direction: column;
			align-items: flex-start;
		}

		.foot-lite-right {
			align-items: flex-start;
		}
	}
</style>
