<script>
	/**
	 * 下载加速：所有带 data-mirror 的下载链接默认指向代理地址（ghfast.top）。
	 * 页面加载后异步探活代理，若 HEAD 请求在 3s 内失败则将 href 回退到 data-src
	 * （原始 GitHub 地址），保证国内慢但可用，国外直链不受影响。
	 *
	 * 探活结果在页面生命周期内只做一次，所有链接统一切换。
	 */
	(function initDownloadFallback() {
		const links = Array.from(
			document.querySelectorAll<HTMLAnchorElement>("a[data-mirror][data-src]"),
		);
		if (links.length === 0) return;

		// 取第一个代理 URL 的 origin 做探活（所有链接同一个代理域名）
		let probeUrl: string;
		try {
			probeUrl = new URL(links[0].dataset.mirror!).origin + "/";
		} catch {
			return; // URL 解析失败，保持当前 href 不动
		}

		const controller = new AbortController();
		const timer = setTimeout(() => controller.abort(), 3000);

		fetch(probeUrl, { method: "HEAD", signal: controller.signal, mode: "no-cors" })
			.then(() => {
				// 代理可达：href 已是镜像地址，无需操作
			})
			.catch(() => {
				// 代理不可达：将所有下载链接的 href 切回原始 GitHub 地址
				for (const link of links) {
					const src = link.dataset.src;
					if (src) link.href = src;
				}
			})
			.finally(() => clearTimeout(timer));
	})();
</script>

<style>
	.download-section {
		padding: 80px 0;
		border-bottom: 1px solid var(--line-soft);
	}

	/* ============== 降级态引导卡（GitHub API 不可达） ============== */
	.dl-degraded {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 16px;
		padding: 56px 32px;
		border: 1px solid var(--line);
		border-radius: var(--radius-sm);
		background: var(--bg-elev);
	}
	.dl-degraded-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 56px;
		height: 56px;
		border-radius: 50%;
		border: 1px solid var(--line-soft);
		color: var(--text-3);
	}
	.dl-degraded-title {
		font-size: 20px;
		font-weight: 600;
		margin: 0;
		color: var(--text);
	}
	.dl-degraded-sub {
		max-width: 560px;
		margin: 0;
		font-size: 14px;
		line-height: 1.6;
		color: var(--text-3);
	}
	.dl-degraded-btn {
		margin-top: 8px;
		display: inline-flex;
		align-items: center;
		gap: 8px;
	}

	/* ============== 顶部头 ============== */
	.download-head {
		display: grid;
		grid-template-columns: 96px 1fr;
		gap: 32px;
		align-items: flex-start;
		margin-bottom: 40px;
	}
	.download-head .index {
		font-size: 11px;
		color: var(--text-3);
		letter-spacing: var(--ls-mono);
		padding-top: 6px;
	}
	.download-head .index b {
		color: var(--text);
		font-weight: 500;
	}
	.download-index {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		color: var(--text);
		font-weight: 500;
		text-transform: uppercase;
	}
	.download-index::before {
		content: "";
		width: 18px;
		height: 1px;
		background: var(--text-3);
	}
	.download-head-body {
		min-width: 0;
	}
	.download-eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: var(--ls-mono);
		text-transform: uppercase;
		color: var(--text-2);
		padding: 6px 12px;
		border: 1px solid var(--line);
		border-radius: var(--radius-sm);
		background: var(--bg-elev);
	}
	.download-eyebrow .dot {
		width: 8px;
		height: 8px;
		flex-shrink: 0;
		background: var(--accent);
	}
	.download-title {
		margin: 14px 0 0;
		font-size: clamp(28px, 4vw, 42px);
		line-height: 1.1;
		letter-spacing: var(--ls-display);
		font-weight: var(--fw-display);
	}
	.download-sub {
		margin: 14px 0 0;
		max-width: 64ch;
		color: var(--text-2);
		font-size: 15px;
		line-height: 1.65;
	}
	.download-head-cta {
		margin-top: 18px;
		display: flex;
		align-items: center;
		gap: 14px;
		flex-wrap: wrap;
	}
	.download-notes-link {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 12px;
		color: var(--text);
		text-decoration: none;
		padding: 6px 12px;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: var(--bg-elev);
		transition:
			border-color 0.15s,
			background 0.15s,
			color 0.15s;
	}
	.download-notes-link:hover {
		border-color: var(--text-4);
		background: var(--bg-hover);
	}
	.download-notes-link .arrow {
		opacity: 0.7;
	}
	.download-version {
		font-size: 11px;
		color: var(--text-3);
		padding: 3px 8px;
		border: 1px solid var(--line);
		border-radius: var(--radius-sm);
		background: var(--bg-elev);
	}

	/* ============== 卡片网格 ============== */
	/* 固定列数（4/2/1）保证 7 张卡 + 1 个 ::after 填充格永远整行排满。
	   每张卡用 subgrid 切成三条跨卡对齐的横带：
	     row 1  卡片头（图标 + 标题）
	     row 2  推荐主下载块
	     row 3  其他版本（details）
	   内容在每条横带内从上到下自然排列,同行各卡的段落起点因此全部对齐;
	   某张卡展开 details 时只撑高第三条横带,邻卡同带跟随、白底填满,
	   不会出现参差或露出容器灰底。 */
	.download-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1px;
		background: var(--line);
		border: 1px solid var(--line);
		border-radius: var(--radius-sm);
		overflow: hidden;
	}
	/* 第 8 格填充：7 张卡在 4 列 (2×4) 与 2 列 (4×2) 下都恰好差 1 格 */
	.download-grid::after {
		content: "";
		background: var(--bg);
		order: 99;
		grid-row: span 3;
	}

	.dl-card {
		display: grid;
		grid-template-rows: subgrid;
		grid-row: span 3;
		align-content: start; /* 无 subgrid 支持时的降级：内容顶对齐 */
		background: var(--bg-elev);
		position: relative;
		transition: background 0.2s;
	}
	.dl-card:hover {
		background: var(--bg-hover);
	}
	.dl-card--ios,
	.dl-card--harmony {
		background: var(--bg);
	}
	.dl-card--ios:hover,
	.dl-card--harmony:hover {
		background: var(--bg);
	}

	/* —— 卡片头 —— */
	.dl-card-head {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 16px 18px;
		border-bottom: 1px solid var(--line-soft);
	}
	.dl-icon {
		width: 36px;
		height: 36px;
		flex-shrink: 0;
		border-radius: var(--radius);
		background: var(--bg-elev-2);
		border: 1px solid var(--line);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--text);
	}
	.dl-head-meta {
		flex: 1;
		min-width: 0;
	}
	.dl-card-title {
		margin: 0;
		font-family: var(--font-mono);
		font-size: 16px;
		font-weight: 600;
		letter-spacing: 0;
	}
	.dl-card-sub {
		margin: 4px 0 0;
		font-size: 11px;
		color: var(--text-3);
		letter-spacing: 0.02em;
	}
	/* —— 统一 tag 视觉高度：固定 height + inline-flex 居中，
	   避免 dl-badge / dl-arch / dl-card-tag 因字号、border、padding 差异参差不齐 —— */
	.dl-card-tag,
	.dl-badge,
	.dl-arch {
		display: inline-flex;
		align-items: center;
		box-sizing: border-box;
		height: 22px;
		padding: 0 8px;
		line-height: 1;
		border-radius: var(--radius-sm);
		white-space: nowrap;
	}

	.dl-card-tag {
		font-size: 10px;
		border: 1px solid var(--line);
		color: var(--text-2);
		background: var(--bg);
		text-transform: lowercase;
		letter-spacing: 0.03em;
	}
	.dl-card-tag--pending {
		color: var(--text-3);
	}

	/* —— 卡片主体 ——
	   display: contents 让 .dl-primary / .dl-others 直接成为卡片 subgrid 的
	   第 2 / 3 行网格项,跨卡横带对齐;内边距下放到两条横带自身。 */
	.dl-card-body {
		display: contents;
	}
	.dl-primary {
		padding: 18px 18px 16px;
	}

	/* —— 推荐下载块 —— */
	.dl-primary-row {
		display: flex;
		align-items: center;
		gap: 8px;
		flex-wrap: wrap;
	}
	.dl-badge {
		font-size: 10px;
		background: var(--accent);
		color: var(--accent-ink);
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}
	.dl-arch {
		font-size: 11px;
		color: var(--text-2);
		border: 1px solid var(--line);
		background: var(--bg);
	}
	.dl-size {
		margin-left: auto;
		font-size: 11px;
		color: var(--text-3);
	}
	.dl-primary-btn {
		margin-top: 10px;
		width: 100%;
		justify-content: center;
		height: 40px;
		font-size: 13px;
	}
	.dl-arrow {
		flex-shrink: 0;
	}
	.dl-btn-text {
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.dl-primary-note {
		margin: 0;
		font-size: 12px;
		color: var(--text-3);
		line-height: 1.55;
	}

	/* —— 其他版本（details/summary）——
	   作为卡片 subgrid 第 3 行的网格项,与同行各卡的"其他版本"带对齐;
	   内容从上到下自然排列,顶部 1px 线与主下载块分隔。 */
	.dl-others {
		border-top: 1px solid var(--line-soft);
		padding: 14px 18px 18px;
		align-self: start;
	}
	.dl-others summary {
		list-style: none;
		cursor: pointer;
		display: flex;
		align-items: center;
		gap: 8px;
		font-size: 12px;
		color: var(--text-2);
		padding: 4px 0;
		transition: color 0.15s;
	}
	.dl-others summary::-webkit-details-marker {
		display: none;
	}
	.dl-others summary:hover {
		color: var(--text);
	}
	.dl-others-count {
		font-size: 10px;
		padding: 1px 6px;
		border: 1px solid var(--line);
		border-radius: var(--radius-sm);
		color: var(--text-3);
		background: var(--bg);
	}
	.dl-chev {
		margin-left: auto;
		color: var(--text-3);
		transition: transform 0.2s;
	}
	.dl-others[open] .dl-chev {
		transform: rotate(180deg);
	}

	.dl-others-list {
		list-style: none;
		margin: 10px 0 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 6px;
	}
	.dl-other {
		margin: 0;
	}
	.dl-other-link {
		display: block;
		padding: 10px 12px;
		border: 1px solid var(--line-soft);
		border-radius: var(--radius);
		background: var(--bg);
		text-decoration: none;
		color: var(--text);
		transition:
			border-color 0.15s,
			background 0.15s,
			color 0.15s;
	}
	.dl-other-link:hover {
		border-color: var(--text-4);
		background: var(--bg-hover);
	}
	.dl-other-top {
		display: flex;
		align-items: baseline;
		gap: 8px;
	}
	.dl-other-label {
		font-size: 13px;
		font-weight: 500;
		color: var(--text);
		flex: 1;
		min-width: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.dl-other-meta {
		font-size: 10px;
		color: var(--text-3);
		display: inline-flex;
		align-items: center;
		gap: 5px;
		flex-shrink: 0;
	}
	.dl-format {
		color: var(--text-2);
	}
	.dl-other-meta .dot {
		opacity: 0.5;
	}
	.dl-other-note {
		margin-top: 4px;
		font-size: 11px;
		color: var(--text-3);
		line-height: 1.5;
	}

	/* —— iOS / 鸿蒙 占位卡 ——
	   占位卡无三段结构,主体作为单个 flex 块跨第 2、3 两行横带,
	   CONTACT 按钮压到底部。 */
	.dl-card-body--pending {
		display: flex;
		flex-direction: column;
		gap: 14px;
		grid-row: span 2;
		padding: 18px;
		justify-content: space-between;
	}
	.dl-ios-note {
		margin: 0;
		font-size: 13px;
		color: var(--text-2);
		line-height: 1.65;
	}
	.dl-ios-cta {
		align-self: flex-start;
		margin-top: 4px;
	}

	/* ============== 底部说明 ============== */
	.download-foot {
		margin-top: 28px;
		display: inline-flex;
		align-items: center;
		gap: 8px;
		flex-wrap: wrap;
		padding: 10px 14px;
		font-size: 11px;
		color: var(--text-3);
		border: 1px solid var(--line-soft);
		border-radius: var(--radius);
		background: var(--bg-elev);
