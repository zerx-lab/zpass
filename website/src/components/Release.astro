---
// ============================================================================
// Release — 下载区块（id=download）
// ---------------------------------------------------------------------------
// 取代原 "即将发布 + build status" 双卡布局。v0.0.2 已正式发布，本区块直接
// 渲染各平台 / 各架构的下载链接：
//
//   - 顶部头：版本徽标 + 章节标题 + 简短说明 + GitHub release notes 链接
//   - 4 个平台卡片：Windows / Linux / Android / 浏览器扩展
//       · 每张卡顶部带 platform icon + 适用范围副标题
//       · 中部 "推荐" 主下载按钮（取数据中第一个 recommended 的 asset）
//       · 折叠展开 "其他版本"：列出剩余架构 / 格式 + 文件大小
//   - 末尾附 iOS 占位卡（开发中）+ SHA-256 校验提示
//
// 资产清单数据源：src/data/release.ts（手工维护，新版本发布后只需更新该文件）。
// ============================================================================

import type { SiteStrings } from "../i18n/strings";
import {
	buildPlatforms,
	formatSize,
	type PlatformGroup,
	type ReleaseAsset,
} from "../data/release";
import { getLatestRelease, RELEASES_LATEST_URL } from "../lib/release-fetcher";

export interface Props {
	t: SiteStrings;
	locale?: "en" | "zh";
	/** 章节背景变体 */
	variant?: "default" | "soft" | "ink" | "blue";
}

const { t, locale = "en", variant = "default" } = Astro.props;
const isZh = locale === "zh";
const sectionClass =
	variant === "default"
		? "download-section"
		: `download-section section--${variant}`;

// SSR 时拉取最新 release。GitHub API 不可达 / 无资产时进入降级态（degraded），
// 此时不渲染任何带版本号的下载直链，改为引导用户前往 GitHub Releases 页面自行下载。
const release = await getLatestRelease();
const degraded = release.degraded;
// 降级态下不构建平台网格，避免渲染出旧版或失效链接。
const PLATFORMS = degraded ? [] : buildPlatforms(release);
const RELEASE_VERSION = release.version;
const RELEASE_TAG_URL = release.tagUrl;

interface Resolved {
	id: PlatformGroup["id"];
	title: string;
	subtitle: string;
	primary: ReleaseAsset;
	primaryLabel: string;
	primaryNote: string;
	/** 主资产是否为应用商店链接（决定主按钮文案 / 是否新标签页打开 / 是否显示体积） */
	isStore: boolean;
	others: Array<{ asset: ReleaseAsset; label: string; note: string }>;
}

// 把 PlatformGroup 解析成当前 locale 下的渲染数据
const resolved: Resolved[] = PLATFORMS.map((p) => {
	const primary = p.assets.find((a) => a.recommended) ?? p.assets[0];
	const others = p.assets
		.filter((a) => a !== primary)
		.map((a) => ({
			asset: a,
			label: isZh ? a.labelZh : a.labelEn,
			note: (isZh ? a.noteZh : a.noteEn) ?? "",
		}));
	return {
		id: p.id,
		title: isZh ? p.titleZh : p.titleEn,
		subtitle: isZh ? p.subtitleZh : p.subtitleEn,
		primary,
		primaryLabel: isZh ? primary.labelZh : primary.labelEn,
		primaryNote: (isZh ? primary.noteZh : primary.noteEn) ?? "",
		isStore: Boolean(primary.storeUrl),
		others,
	};
});
---

<section class={sectionClass} id="download">
	<div class="wrap">
		<!-- ========== 顶部头 ========== -->
		<div class="download-head reveal">
			<div class="index mono download-index">
				{t.download_section_label}
			</div>
			<div class="download-head-body">
				<div class="download-eyebrow mono">
					<span class="dot" aria-hidden="true"></span>
					{t.release_eyebrow}
				</div>
				<h2 class="download-title">{t.release_title}</h2>
				<p class="download-sub">{t.release_sub}</p>
				<div class="download-head-cta">
					<a
						class="download-notes-link mono"
						href={RELEASE_TAG_URL}
						target="_blank"
						rel="noopener"
					>
						{t.download_release_notes}
						<span class="arrow" aria-hidden="true">→</span>
					</a>
					{!degraded && (
						<span class="download-version mono">{RELEASE_VERSION}</span>
					)}
				</div>
			</div>
		</div>

		{degraded && (
			<div class="dl-degraded reveal">
				<div class="dl-degraded-icon" aria-hidden="true">
					<svg
						viewBox="0 0 24 24"
						width="28"
						height="28"
						fill="none"
						stroke="currentColor"
						stroke-width="1.6"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
						<path d="M7 10l5 5 5-5" />
						<path d="M12 15V3" />
					</svg>
				</div>
				<h3 class="dl-degraded-title">
					{isZh ? "无法获取最新版本信息" : "Couldn't load the latest release"}
				</h3>
				<p class="dl-degraded-sub">
					{isZh
						? "GitHub 接口暂时不可用，为避免下载到旧版本，请前往 GitHub Releases 页面自行下载最新安装包。"
						: "GitHub's API is temporarily unavailable. To avoid downloading an outdated build, please grab the latest installer from the GitHub Releases page."}
				</p>
				<a
					class="btn primary dl-degraded-btn"
					href={RELEASES_LATEST_URL}
					target="_blank"
					rel="noopener"
				>
					<span class="dl-btn-text">
						{isZh ? "前往 GitHub Releases" : "Open GitHub Releases"}
					</span>
					<span class="arrow" aria-hidden="true">→</span>
				</a>
			</div>
		)}

		<!-- ========== 平台下载卡片网格 ========== -->
		{!degraded && (
		<div class="download-grid">
			{
				resolved.map((p) => (
					<article class={`dl-card dl-card--${p.id} reveal`}>
						<header class="dl-card-head">
							<span class="dl-icon" aria-hidden="true">
								{p.id === "macos" && (
									<svg
										viewBox="0 0 24 24"
										width="22"
										height="22"
										fill="currentColor"
										role="img"
										aria-label="Apple"
									>
										<path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z" />
									</svg>
								)}
								{p.id === "windows" && (
									<svg
										viewBox="0 0 24 24"
										width="22"
										height="22"
										fill="currentColor"
									>
										<path d="M3 5.5l8-1.1v8.1H3V5.5zm0 13l8 1.1V11.6H3V18.5zm9 1.3l9 1.2V11.6h-9v8.2zm0-15.6V12h9V3l-9 1.2z" />
									</svg>
								)}
								{p.id === "linux" && (
									<svg
										viewBox="0 0 24 24"
										width="22"
										height="22"
										fill="currentColor"
										role="img"
										aria-label="Linux"
									>
										<path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.587-.003 1.23-.269 2.26-.334.699-.058 1.574.267 2.577.2.025.134.063.198.114.333l.003.003c.391.778 1.113 1.132 1.884 1.071.771-.06 1.592-.536 2.257-1.306.631-.765 1.683-1.084 2.378-1.503.348-.199.629-.469.649-.853.023-.4-.2-.811-.714-1.376v-.097l-.003-.003c-.17-.2-.25-.535-.338-.926-.085-.401-.182-.786-.492-1.046h-.003c-.059-.054-.123-.067-.188-.135a.357.357 0 00-.19-.064c.431-1.278.264-2.55-.173-3.694-.533-1.41-1.465-2.638-2.175-3.483-.796-1.005-1.576-1.957-1.56-3.368.026-2.152.236-6.133-3.544-6.139zm.529 3.405h.013c.213 0 .396.062.584.198.19.135.33.332.438.533.105.259.158.459.166.724 0-.02.006-.04.006-.06v.105a.086.086 0 01-.004-.021l-.004-.024a1.807 1.807 0 01-.15.706.953.953 0 01-.213.335.71.71 0 00-.088-.042c-.104-.045-.198-.064-.284-.133a1.312 1.312 0 00-.22-.066c.05-.06.146-.133.183-.198.053-.128.082-.264.088-.402v-.02a1.21 1.21 0 00-.061-.4c-.045-.134-.101-.2-.183-.333-.084-.066-.167-.132-.267-.132h-.016c-.093 0-.176.03-.262.132a.8.8 0 00-.205.334 1.18 1.18 0 00-.09.4v.019c.002.089.008.179.02.267-.193-.067-.438-.135-.607-.202a1.635 1.635 0 01-.018-.2v-.02a1.772 1.772 0 01.15-.768c.082-.22.232-.406.43-.533a.985.985 0 01.594-.2zm-2.962.059h.036c.142 0 .27.048.399.135.146.129.264.288.344.465.09.199.14.4.153.667v.004c.007.134.006.2-.002.266v.08c-.03.007-.056.018-.083.024-.152.055-.274.135-.393.2.012-.09.013-.18.003-.267v-.015c-.012-.133-.04-.2-.082-.333a.613.613 0 00-.166-.267.248.248 0 00-.183-.064h-.021c-.071.006-.13.04-.186.132a.552.552 0 00-.12.27.944.944 0 00-.023.33v.015c.012.135.037.2.08.334.046.134.098.2.166.268.01.009.02.018.034.024-.07.057-.117.07-.176.136a.304.304 0 01-.131.068 2.62 2.62 0 01-.275-.402 1.772 1.772 0 01-.155-.667 1.759 1.759 0 01.08-.668 1.43 1.43 0 01.283-.535c.128-.133.26-.2.418-.2zm1.37 1.706c.332 0 .733.065 1.216.399.293.2.523.269 1.052.468h.003c.255.136.405.266.478.399v-.131a.571.571 0 01.016.47c-.123.31-.516.643-1.063.842v.002c-.268.135-.501.333-.775.465-.276.135-.588.292-1.012.267a1.139 1.139 0 01-.448-.067 3.566 3.566 0 01-.322-.198c-.195-.135-.363-.332-.612-.465v-.005h-.005c-.4-.246-.616-.512-.686-.71-.07-.268-.005-.47.193-.6.224-.135.38-.271.483-.336.104-.074.143-.102.176-.131h.002v-.003c.169-.202.436-.47.839-.601.139-.036.294-.065.466-.065zm2.8 2.142c.358 1.417 1.196 3.475 1.735 4.473.286.534.855 1.659 1.102 3.024.156-.005.33.018.513.064.646-1.671-.546-3.467-1.089-3.966-.22-.2-.232-.335-.123-.335.59.534 1.365 1.572 1.646 2.757.13.535.16 1.104.021 1.67.067.028.135.06.205.067 1.032.534 1.413.938 1.23 1.537v-.043c-.06-.003-.12 0-.18 0h-.016c.151-.467-.182-.825-1.065-1.224-.915-.4-1.646-.336-1.77.465-.008.043-.013.066-.018.135-.068.023-.139.053-.209.064-.43.268-.662.669-.793 1.187-.13.533-.17 1.156-.205 1.869v.003c-.02.334-.17.838-.319 1.35-1.5 1.072-3.58 1.538-5.348.334a2.645 2.645 0 00-.402-.533 1.45 1.45 0 00-.275-.333c.182 0 .338-.03.465-.067a.615.615 0 00.314-.334c.108-.267 0-.697-.345-1.163-.345-.467-.931-.995-1.788-1.521-.63-.4-.986-.87-1.15-1.396-.165-.534-.143-1.085-.015-1.645.245-1.07.873-2.11 1.274-2.763.107-.065.037.135-.408.974-.396.751-1.14 2.497-.122 3.854a8.123 8.123 0 01.647-2.876c.564-1.278 1.743-3.504 1.836-5.268.048.036.217.135.289.202.218.133.38.333.59.465.21.201.477.335.876.335.039.003.075.006.11.006.412 0 .73-.134.997-.268.29-.134.52-.334.74-.4h.005c.467-.135.835-.402 1.044-.7zm2.185 8.958c.037.6.343 1.245.882 1.377.588.134 1.434-.333 1.791-.765l.211-.01c.315-.007.577.01.847.268l.003.003c.208.199.305.53.391.876.085.4.154.78.409 1.066.486.527.645.906.636 1.14l.003-.007v.018l-.003-.012c-.015.262-.185.396-.498.595-.63.401-1.746.712-2.457 1.57-.618.737-1.37 1.14-2.036 1.191-.664.053-1.237-.2-1.574-.898l-.005-.003c-.21-.4-.12-1.025.056-1.69.176-.668.428-1.344.463-1.897.037-.714.076-1.335.195-1.814.12-.465.308-.797.641-.984l.045-.022zm-10.814.049h.01c.053 0 .105.005.157.014.376.055.706.333 1.023.752l.91 1.664.003.003c.243.533.754 1.064 1.189 1.637.434.598.77 1.131.729 1.57v.006c-.057.744-.48 1.148-1.125 1.294-.645.135-1.52.002-2.395-.464-.968-.536-2.118-.469-2.857-.602-.369-.066-.61-.2-.723-.4-.11-.2-.113-.602.123-1.23v-.004l.002-.003c.117-.334.03-.752-.027-1.118-.055-.401-.083-.71.043-.94.16-.334.396-.4.69-.533.294-.135.64-.202.915-.47h.002v-.002c.256-.268.445-.601.668-.838.19-.201.38-.336.663-.336zm7.159-9.074c-.435.201-.945.535-1.488.535-.542 0-.97-.267-1.28-.466-.154-.134-.28-.268-.373-.335-.164-.134-.144-.333-.074-.333.109.016.129.134.199.2.096.066.215.2.36.333.292.2.68.467 1.167.467.485 0 1.053-.267 1.398-.466.195-.135.445-.334.648-.467.156-.136.149-.267.279-.267.128.016.034.134-.147.332a8.097 8.097 0 01-.69.468zm-1.082-1.583V5.64c-.006-.02.013-.042.029-.05.074-.043.18-.027.26.004.063 0 .16.067.15.135-.006.049-.085.066-.135.066-.055 0-.092-.043-.141-.068-.052-.018-.146-.008-.163-.065zm-.551 0c-.02.058-.113.049-.166.066-.047.025-.086.068-.14.068-.05 0-.13-.02-.136-.068-.01-.066.088-.133.15-.133.08-.031.184-.047.259-.005.019.009.036.03.03.05v.02h.003z" />
									</svg>
								)}
								{p.id === "android" && (
									<svg
										viewBox="0 0 24 24"
										width="22"
										height="22"
										fill="currentColor"
										role="img"
										aria-label="Android"
									>
										<path d="M18.4395 5.5586c-.675 1.1664-1.352 2.3318-2.0274 3.498-.0366-.0155-.0742-.0286-.1113-.043-1.8249-.6957-3.484-.8-4.42-.787-1.8551.0185-3.3544.4643-4.2597.8203-.084-.1494-1.7526-3.021-2.0215-3.4864a1.1451 1.1451 0 0 0-.1406-.1914c-.3312-.364-.9054-.4859-1.379-.203-.475.282-.7136.9361-.3886 1.5019 1.9466 3.3696-.0966-.2158 1.9473 3.3593.0172.031-.4946.2642-1.3926 1.0177C2.8987 12.176.452 14.772 0 18.9902h24c-.119-1.1108-.3686-2.099-.7461-3.0683-.7438-1.9118-1.8435-3.2928-2.7402-4.1836a12.1048 12.1048 0 0 0-2.1309-1.6875c.6594-1.122 1.312-2.2559 1.9649-3.3848.2077-.3615.1886-.7956-.0079-1.1191a1.1001 1.1001 0 0 0-.8515-.5332c-.5225-.0536-.9392.3128-1.0488.5449zm-.0391 8.461c.3944.5926.324 1.3306-.1563 1.6503-.4799.3197-1.188.0985-1.582-.4941-.3944-.5927-.324-1.3307.1563-1.6504.4727-.315 1.1812-.1086 1.582.4941zM7.207 13.5273c.4803.3197.5506 1.0577.1563 1.6504-.394.5926-1.1038.8138-1.584.4941-.48-.3197-.5503-1.0577-.1563-1.6504.4008-.6021 1.1087-.8106 1.584-.4941z" />
									</svg>
								)}
								{p.id === "extension" && (
									<svg
										viewBox="0 0 24 24"
										width="22"
										height="22"
										fill="none"
										stroke="currentColor"
										stroke-width="1.6"
										stroke-linecap="round"
										stroke-linejoin="round"
									>
										<path d="M5 8h6V5a2 2 0 114 0v3h4v4h-3a2 2 0 100 4h3v4H5v-6H2a2 2 0 110-4h3V8z" />
									</svg>
								)}
							</span>
							<div class="dl-head-meta">
								<h3 class="dl-card-title">{p.title}</h3>
								<p class="dl-card-sub mono">{p.subtitle}</p>
							</div>
							<span class="dl-card-tag mono">
								{p.primary.format}
							</span>
						</header>

						<div class="dl-card-body">
							<div class="dl-primary">
								<div class="dl-primary-row">
									<span class="dl-badge mono">
										{t.download_recommended}
									</span>
									<span class="dl-arch mono">{p.primary.arch}</span>
									{!p.isStore && (
										<span class="dl-size mono">
											{formatSize(p.primary.sizeBytes)}
										</span>
									)}
								</div>
								<a
									class="btn primary dl-primary-btn"
									href={p.primary.mirrorUrl ?? p.primary.url}
									data-src={p.primary.url}
									{...(p.primary.mirrorUrl
										? { "data-mirror": p.primary.mirrorUrl }
										: {})}
									rel="noopener"
									{...p.isStore
										? { target: "_blank" }
										: { download: true }}
								>
									{p.isStore ? (
										<svg
											class="dl-arrow"
											viewBox="0 0 24 24"
											width="14"
											height="14"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											stroke-linecap="round"
											stroke-linejoin="round"
											aria-hidden="true"
										>
											<path d="M7 17L17 7" />
											<path d="M8 7h9v9" />
										</svg>
									) : (
										<svg
											class="dl-arrow"
											viewBox="0 0 24 24"
											width="14"
											height="14"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											stroke-linecap="round"
											stroke-linejoin="round"
											aria-hidden="true"
										>
											<path d="M12 4v12" />
											<path d="M6 12l6 6 6-6" />
											<path d="M4 20h16" />
										</svg>
									)}
									<span class="dl-btn-text">
										{p.isStore
											? isZh
												? "前往 Chrome 应用商店安装"
												: "Get it on the Chrome Web Store"
											: p.primaryLabel}
									</span>
								</a>
								{p.primaryNote && (
									<p class="dl-primary-note">{p.primaryNote}</p>
								)}
							</div>

							{p.others.length > 0 && (
								<details class="dl-others">
									<summary>
										<span>{t.download_more_variants}</span>
										<span class="dl-others-count mono">
											{p.others.length}
										</span>
										<svg
											class="dl-chev"
											viewBox="0 0 24 24"
											width="13"
											height="13"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											stroke-linecap="round"
											stroke-linejoin="round"
											aria-hidden="true"
										>
											<path d="M6 9l6 6 6-6" />
										</svg>
									</summary>

									<ul class="dl-others-list">
										{p.others.map(({ asset, label, note }) => (
											<li class="dl-other">
												<a
													class="dl-other-link"
													href={asset.mirrorUrl ?? asset.url}
													data-src={asset.url}
													{...(asset.mirrorUrl
														? { "data-mirror": asset.mirrorUrl }
														: {})}
													rel="noopener"
													download
												>
													<div class="dl-other-top">
														<span class="dl-other-label">
															{label}
														</span>
														<span class="dl-other-meta mono">
															<span class="dl-format">{asset.format}</span>
															<span class="dot" aria-hidden="true">·</span>
															<span>{formatSize(asset.sizeBytes)}</span>
														</span>
													</div>
													{note && (
														<div class="dl-other-note">{note}</div>
													)}
												</a>
											</li>
										))}
									</ul>
								</details>
							)}
						</div>
					</article>
				))
			}

			<!-- ========== iOS 占位卡 ========== -->
			<article class="dl-card dl-card--ios reveal">
				<header class="dl-card-head">
					<span class="dl-icon" aria-hidden="true">
