---
// ============================================================================
// Changelog — 最近一次 release 的更新日志
// ---------------------------------------------------------------------------
// 内容来源：GitHub Releases API（src/lib/release-fetcher.ts），
// 其中 release body 由 .github/workflows/release-notes.yml 在 tag 推送时
// 通过 git-cliff（cliff.toml）生成 —— 单点产出，避免人工维护。
//
// 设计要点：
//   - SSR 时直接拉取，并通过 24h 模块缓存复用；
//   - body 字段是 git-cliff 输出的子集（## / ### / - 列表 + **scope** 加粗），
//     用一个就地的小渲染器解析为安全 HTML，无需引入额外依赖；
//   - API 失败或 body 为空时，data/release.ts 的兜底文案接管。
// ============================================================================

import type { SiteStrings } from "../i18n/strings";
import { getLatestRelease } from "../lib/release-fetcher";

export interface Props {
	t: SiteStrings;
	/** 章节背景变体 */
	variant?: "default" | "soft" | "ink" | "blue";
}

const { t, variant = "default" } = Astro.props;
const sectionClass =
	variant === "default" ? "section" : `section section--${variant}`;

const release = await getLatestRelease();

// ---------------------------------------------------------------------------
// 小型 markdown 渲染器
// ---------------------------------------------------------------------------
// 只覆盖 git-cliff 模板会用到的子集，刻意不引入第三方解析器：
//   - `## text`  → 版本标题（h3）
//   - `### text` → 分组标题（h4）
//   - `- text`   → 列表项；连续 `-` 行自动合并为 <ul>
//   - 行内：`**text**` → <strong>，`` `text` `` → <code>
//
// 安全考量：在做任何 markdown 替换前，先把整段文本里的 HTML 特殊字符整体转义。
// 这样即使 release body 被人改成包含 `<script>` 也只会显示为文字，绝不会被
// 当成 HTML 解析；之后的 `**` / 反引号替换只针对 markdown 语法，不会重新引入
// HTML 注入面。
function escapeHtml(s: string): string {
	return s
		.replace(/&/g, "&amp;")
		.replace(/</g, "&lt;")
		.replace(/>/g, "&gt;")
		.replace(/"/g, "&quot;")
		.replace(/'/g, "&#39;");
}

function inline(s: string): string {
	// 注意：先转义再处理 markdown 标记 —— 标记字符（*、`）不在转义集合里，
	// 因此可以放心替换。
	return escapeHtml(s)
		.replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
		.replace(/`([^`]+)`/g, "<code>$1</code>");
}

function renderCliffBody(md: string): string {
	const lines = md.split("\n");
	const out: string[] = [];
	let inList = false;
	const closeList = () => {
		if (inList) {
			out.push("</ul>");
			inList = false;
		}
	};
	for (const raw of lines) {
		const line = raw.trimEnd();
		if (line.startsWith("## ")) {
			closeList();
			out.push(`<h3 class="cl-version">${inline(line.slice(3))}</h3>`);
		} else if (line.startsWith("### ")) {
			closeList();
			out.push(`<h4 class="cl-group">${inline(line.slice(4))}</h4>`);
		} else if (line.startsWith("- ")) {
			if (!inList) {
				out.push('<ul class="cl-list">');
				inList = true;
			}
			out.push(`<li>${inline(line.slice(2))}</li>`);
		} else if (line === "") {
			closeList();
		} else {
			closeList();
			out.push(`<p class="cl-para">${inline(line)}</p>`);
		}
	}
	closeList();
	return out.join("\n");
}

const bodyHtml = renderCliffBody(release.body);
---

<section class={sectionClass} id="changelog">
	<div class="wrap">
		<div class="sec-head reveal">
			<div class="index mono">
				<b>08</b> / {t.changelog_section_label}
			</div>
			<div>
				<h2>{t.section_changelog}</h2>
				<div class="sec-sub">{t.section_changelog_sub}</div>
			</div>
		</div>

		<article class="changelog-card reveal">
			<header class="changelog-card-head">
				<span class="changelog-tag mono">{release.version}</span>
				<a
					class="changelog-link mono"
					href={release.tagUrl}
					target="_blank"
					rel="noopener"
				>
					{t.changelog_view_on_github}
					<span class="arrow" aria-hidden="true">→</span>
				</a>
			</header>

			<div class="changelog-body" set:html={bodyHtml} />

			<footer class="changelog-card-foot">
				<a
					class="changelog-all mono"
					href="https://github.com/zerx-lab/zpass/releases"
					target="_blank"
					rel="noopener"
				>
					{t.changelog_view_all_releases}
					<span class="arrow" aria-hidden="true">→</span>
				</a>
			</footer>
		</article>
	</div>
</section>

<style>
	.changelog-card {
		border: 1px solid var(--line);
		border-radius: var(--radius-lg);
		background: var(--bg-elev);
		padding: 24px 26px;
		display: flex;
		flex-direction: column;
		gap: 18px;
	}

	.changelog-card-head {
		display: flex;
		align-items: center;
		gap: 12px;
		flex-wrap: wrap;
		padding-bottom: 14px;
		border-bottom: 1px solid var(--line-soft);
	}

	.changelog-tag {
		display: inline-flex;
		align-items: center;
		height: 24px;
		padding: 0 10px;
		font-size: 12px;
		font-weight: 600;
		color: var(--accent-ink);
		background: var(--accent);
		border-radius: 4px;
		letter-spacing: 0.02em;
	}

	.changelog-link {
		margin-left: auto;
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 12px;
		color: var(--text-2);
		text-decoration: none;
		padding: 4px 10px;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: var(--bg);
		transition:
			border-color 0.15s,
			color 0.15s,
			background 0.15s;
	}
	.changelog-link:hover {
		color: var(--text);
		border-color: var(--text-4);
		background: var(--bg-hover);
	}
	.changelog-link .arrow {
		opacity: 0.7;
	}

	.changelog-body {
		font-size: 14px;
		line-height: 1.7;
		color: var(--text);
	}
	.changelog-body :global(.cl-version) {
		font-size: 16px;
		margin: 0 0 4px;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: var(--text-2);
	}
	.changelog-body :global(.cl-version:not(:first-child)) {
		margin-top: 22px;
	}
	.changelog-body :global(.cl-group) {
		margin: 18px 0 8px;
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--text-3);
	}
	.changelog-body :global(.cl-list) {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 6px;
	}
	.changelog-body :global(.cl-list li) {
		position: relative;
		padding-left: 18px;
		font-size: 13.5px;
		line-height: 1.6;
		color: var(--text);
	}
	.changelog-body :global(.cl-list li::before) {
		content: "";
		position: absolute;
		left: 4px;
		top: 0.7em;
		width: 6px;
		height: 1px;
		background: var(--text-3);
	}
	.changelog-body :global(strong) {
		color: var(--text);
		font-weight: 600;
		margin-right: 2px;
	}
	.changelog-body :global(code) {
		font-family: var(--font-mono, ui-monospace, monospace);
		font-size: 0.92em;
		padding: 1px 5px;
		border: 1px solid var(--line);
		border-radius: 3px;
		background: var(--bg);
		color: var(--text-2);
	}
	.changelog-body :global(.cl-para) {
		margin: 0 0 8px;
		font-size: 13.5px;
		color: var(--text-2);
	}

	.changelog-card-foot {
		padding-top: 14px;
		border-top: 1px solid var(--line-soft);
		display: flex;
		justify-content: flex-end;
	}
	.changelog-all {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 12px;
		color: var(--text-2);
		text-decoration: none;
		padding: 4px 10px;
		border-radius: var(--radius);
		transition: color 0.15s;
	}
	.changelog-all:hover {
		color: var(--text);
	}
	.changelog-all .arrow {
		opacity: 0.7;
	}

	@media (max-width: 720px) {
		.changelog-card {
			padding: 20px 18px;
		}
		.changelog-link {
			margin-left: 0;
		}
	}
</style>
