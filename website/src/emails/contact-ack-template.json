{
  "name": "ZPass – Contact Ack",
  "type": "tx",
  "subject": "We received your message — ZPass",
  "body": "{{ $zh := eq .Tx.Data.lang \"zh\" -}}\n<!doctype html>\n<html lang=\"{{ if $zh }}zh-CN{{ else }}en{{ end }}\">\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    <meta name=\"color-scheme\" content=\"dark\" />\n    <title>{{ if $zh }}已收到你的消息{{ else }}We received your message{{ end }}</title>\n    <style>\n      body { margin:0;padding:0;background:#0c0c0d; }\n      a { text-decoration:none; }\n      @media (max-width:620px) {\n        .zp-shell { width:100%!important; padding:24px 16px!important; }\n        .zp-card  { padding:28px 20px!important; border-radius:10px!important; }\n        .zp-h1    { font-size:20px!important; }\n      }\n    </style>\n  </head>\n  <body style=\"margin:0;padding:0;background:#0c0c0d;font-family:'Geist',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue','PingFang SC','Hiragino Sans GB','Microsoft YaHei',Arial,sans-serif;color:#ececec;-webkit-font-smoothing:antialiased;\">\n\n    <!-- 预览文字 -->\n    <div style=\"display:none;max-height:0;overflow:hidden;mso-hide:all;font-size:1px;line-height:1px;color:#0c0c0d;opacity:0;\">\n      {{ if $zh }}我们已经收到了你的消息，将尽快回复你。{{ else }}We got your message and will get back to you soon.{{ end }}\n    </div>\n\n    <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#0c0c0d;\">\n      <tr><td align=\"center\" style=\"padding:48px 16px;\">\n\n        <table role=\"presentation\" class=\"zp-shell\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"width:600px;max-width:600px;\">\n\n          <!-- 品牌头 -->\n          <tr><td style=\"padding:0 4px 20px 4px;\">\n            <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"><tr>\n              <td align=\"left\" style=\"font-size:15px;font-weight:600;letter-spacing:-0.01em;color:#ececec;\">ZPass</td>\n              <td align=\"right\" style=\"font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:11px;letter-spacing:0.08em;color:#6e6e73;text-transform:uppercase;\">{{ if $zh }}消息回执{{ else }}MESSAGE RECEIPT{{ end }}</td>\n            </tr></table>\n          </td></tr>\n\n          <!-- 主卡片 -->\n          <tr><td class=\"zp-card\" style=\"background:#111113;border:1px solid #232328;border-radius:10px;padding:40px 40px 36px 40px;\">\n\n            <!-- eyebrow -->\n            <p style=\"margin:0 0 18px 0;font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:11px;letter-spacing:0.12em;color:#6e6e73;text-transform:uppercase;\">{{ if $zh }}已收到{{ else }}RECEIVED{{ end }}</p>\n\n            <!-- 标题 -->\n            <h1 class=\"zp-h1\" style=\"margin:0 0 16px 0;font-size:24px;line-height:1.3;font-weight:600;letter-spacing:-0.02em;color:#ececec;\">{{ if $zh }}你好，{{ .Tx.Data.sender_name }}。{{ else }}Hey {{ .Tx.Data.sender_name }},{{ end }}</h1>\n\n            <!-- 正文 -->\n            <p style=\"margin:0 0 28px 0;font-size:14px;line-height:1.65;color:#a8a8ac;\">{{ if $zh }}我们已经收到了你的消息，通常会在 1–2 个工作日内回复。如有紧急事项，可以直接回复本邮件。{{ else }}We received your message and will get back to you within 1–2 business days. If it's urgent, feel free to reply directly to this email.{{ end }}</p>\n\n            <!-- 分隔线 -->\n            <hr style=\"margin:0 0 24px 0;border:none;border-top:1px solid #232328;height:0;\" />\n\n            <!-- 消息摘要（展示用户自己发送的内容供确认） -->\n            <p style=\"margin:0 0 10px 0;font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:11px;letter-spacing:0.08em;color:#6e6e73;text-transform:uppercase;\">{{ if $zh }}你的消息{{ else }}YOUR MESSAGE{{ end }}</p>\n            <div style=\"background:#16161a;border:1px solid #232328;border-radius:7px;padding:16px;font-size:13px;color:#a8a8ac;line-height:1.65;white-space:pre-wrap;\">{{ .Tx.Data.contact_message }}</div>\n\n          </td></tr>\n\n          <!-- 说明条 -->\n          <tr><td style=\"padding:20px 4px 0 4px;\">\n            <p style=\"margin:0;font-size:12px;line-height:1.6;color:#6e6e73;\">{{ if $zh }}如果这不是你发起的操作，可以安全忽略本邮件。{{ else }}If you didn't send this message, you can safely ignore this email.{{ end }}</p>\n          </td></tr>\n\n          <!-- 页脚 -->\n          <tr><td style=\"padding:16px 4px 0 4px;\">\n            <p style=\"margin:0;font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:11px;letter-spacing:0.04em;color:#45454a;\">{{ if $zh }}&#x00A9; 2026 ZPass &middot; 端到端加密的密码管理器{{ else }}&#x00A9; 2026 ZPass &middot; End-to-end encrypted password manager{{ end }}</p>\n          </td></tr>\n\n        </table>\n      </td></tr>\n    </table>\n  </body>\n</html>"
}
