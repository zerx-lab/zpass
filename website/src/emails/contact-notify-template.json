{
  "name": "ZPass – Contact Notify",
  "type": "tx",
  "subject": "[ZPass] New contact message",
  "body": "{{ $zh := eq .Tx.Data.lang \"zh\" -}}\n<!doctype html>\n<html lang=\"{{ if $zh }}zh-CN{{ else }}en{{ end }}\">\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    <meta name=\"color-scheme\" content=\"dark\" />\n    <title>{{ if $zh }}新联系消息{{ else }}New Contact Message{{ end }}</title>\n    <style>\n      body { margin:0;padding:0;background:#0c0c0d; }\n      a { text-decoration:none; }\n      @media (max-width:620px) {\n        .zp-shell { width:100%!important; padding:24px 16px!important; }\n        .zp-card  { padding:28px 20px!important; border-radius:10px!important; }\n      }\n    </style>\n  </head>\n  <body style=\"margin:0;padding:0;background:#0c0c0d;font-family:'Geist',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue','PingFang SC','Hiragino Sans GB','Microsoft YaHei',Arial,sans-serif;color:#ececec;-webkit-font-smoothing:antialiased;\">\n\n    <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#0c0c0d;\">\n      <tr><td align=\"center\" style=\"padding:48px 16px;\">\n\n        <table role=\"presentation\" class=\"zp-shell\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"width:600px;max-width:600px;\">\n\n          <!-- 品牌头 -->\n          <tr><td style=\"padding:0 4px 20px 4px;\">\n            <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"><tr>\n              <td align=\"left\" style=\"font-size:15px;font-weight:600;letter-spacing:-0.01em;color:#ececec;\">ZPass</td>\n              <td align=\"right\" style=\"font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:11px;letter-spacing:0.08em;color:#6e6e73;text-transform:uppercase;\">{{ if $zh }}官网联系{{ else }}WEBSITE CONTACT{{ end }}</td>\n            </tr></table>\n          </td></tr>\n\n          <!-- 主卡片 -->\n          <tr><td class=\"zp-card\" style=\"background:#111113;border:1px solid #232328;border-radius:10px;padding:40px 40px 36px 40px;\">\n\n            <!-- eyebrow -->\n            <p style=\"margin:0 0 18px 0;font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:11px;letter-spacing:0.12em;color:#6e6e73;text-transform:uppercase;\">{{ if $zh }}新消息{{ else }}NEW MESSAGE{{ end }}</p>\n\n            <!-- 标题 -->\n            <h1 style=\"margin:0 0 28px 0;font-size:22px;line-height:1.3;font-weight:600;letter-spacing:-0.02em;color:#ececec;\">{{ if $zh }}来自官网的联系消息{{ else }}New message from your website{{ end }}</h1>\n\n            <!-- 信息表格 -->\n            <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"border:1px solid #232328;border-radius:7px;border-collapse:separate;overflow:hidden;margin:0 0 28px 0;\">\n              <tr><td style=\"padding:12px 16px;border-bottom:1px solid #232328;background:#16161a;\">\n                <span style=\"font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:11px;letter-spacing:0.08em;color:#6e6e73;text-transform:uppercase;\">{{ if $zh }}姓名{{ else }}NAME{{ end }}</span>\n                <div style=\"font-size:14px;color:#ececec;margin-top:5px;\">{{ .Tx.Data.sender_name }}</div>\n              </td></tr>\n              <tr><td style=\"padding:12px 16px;border-bottom:1px solid #232328;background:#16161a;\">\n                <span style=\"font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:11px;letter-spacing:0.08em;color:#6e6e73;text-transform:uppercase;\">{{ if $zh }}邮箱{{ else }}EMAIL{{ end }}</span>\n                <div style=\"margin-top:5px;\"><a href=\"mailto:{{ .Tx.Data.sender_email }}\" style=\"font-size:14px;color:#ececec;font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;\">{{ .Tx.Data.sender_email }}</a></div>\n              </td></tr>\n              <tr><td style=\"padding:12px 16px;border-bottom:1px solid #232328;background:#16161a;\">\n                <span style=\"font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:11px;letter-spacing:0.08em;color:#6e6e73;text-transform:uppercase;\">{{ if $zh }}类型{{ else }}TYPE{{ end }}</span>\n                <div style=\"font-size:14px;color:#ececec;margin-top:5px;\">{{ .Tx.Data.contact_type }}</div>\n              </td></tr>\n              <tr><td style=\"padding:12px 16px;background:#16161a;\">\n                <span style=\"font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:11px;letter-spacing:0.08em;color:#6e6e73;text-transform:uppercase;\">{{ if $zh }}内容{{ else }}MESSAGE{{ end }}</span>\n                <div style=\"font-size:14px;color:#ececec;line-height:1.65;margin-top:6px;white-space:pre-wrap;\">{{ .Tx.Data.contact_message }}</div>\n              </td></tr>\n            </table>\n\n            <!-- 回复按钮 -->\n            <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n              <tr><td align=\"center\" style=\"border-radius:7px;background:#ececec;\">\n                <a href=\"mailto:{{ .Tx.Data.sender_email }}\" style=\"display:inline-block;padding:11px 24px;font-size:13px;font-weight:600;letter-spacing:-0.01em;color:#0c0c0d;background:#ececec;border-radius:7px;text-decoration:none;\">{{ if $zh }}直接回复 &#x2192;{{ else }}Reply directly &#x2192;{{ end }}</a>\n              </td></tr>\n            </table>\n\n          </td></tr>\n\n          <!-- 页脚 -->\n          <tr><td style=\"padding:20px 4px 0 4px;\">\n            <p style=\"margin:0;font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:11px;letter-spacing:0.04em;color:#45454a;\">{{ if $zh }}&#x00A9; 2026 ZPass &middot; 官网联系通知{{ else }}&#x00A9; 2026 ZPass &middot; Website contact notification{{ end }}</p>\n          </td></tr>\n\n        </table>\n      </td></tr>\n    </table>\n  </body>\n</html>"
}
