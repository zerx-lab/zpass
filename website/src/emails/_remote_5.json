{"data":{"id":5,"created_at":"2026-04-21T06:50:59.177081Z","updated_at":"2026-04-21T07:55:10.707148Z","name":"ZPass – Confirm subscription","subject":"Confirm your ZPass subscription","type":"tx","body":"\u003c!--\r\n  ZPass — 订阅确认邮件 (Transactional · 双语)\r\n  SUBJECT: 由 /api/tx 的 `subject` 字段按语言动态传入\r\n          - en: Confirm your ZPass subscription\r\n          - zh: 确认订阅 ZPass 早期通知\r\n  变量:\r\n    - {{ .Subscriber.Email }}          订阅者邮箱（/api/tx 的 subscriber_emails 自动绑定）\r\n    - {{ .Tx.Data.optin_url }}         双重确认链接（必须由调用方注入）\r\n    - {{ .Tx.Data.unsub_url }}         退订链接（可选）\r\n    - {{ .Tx.Data.lang }}              \"zh\" | \"en\"（默认 en；缺省或其他值都按 en 渲染）\r\n  备注:\r\n    listmonk v5 的 Transactional 模板上下文仅暴露 { Subscriber, Tx }，\r\n    没有 .OptinURL / .UnsubURL 字段——必须通过 .Tx.Data.* 由调用方显式注入。\r\n  设计: 与 ZPass 官网 tokens.css 暗色主题同源\r\n--\u003e\r\n{{ $zh := eq .Tx.Data.lang \"zh\" -}}\r\n\u003c!doctype html\u003e\r\n\u003chtml lang=\"{{ if $zh }}zh-CN{{ else }}en{{ end }}\"\u003e\r\n  \u003chead\u003e\r\n    \u003cmeta charset=\"utf-8\" /\u003e\r\n    \u003cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1\" /\u003e\r\n    \u003cmeta name=\"color-scheme\" content=\"dark\" /\u003e\r\n    \u003cmeta name=\"supported-color-schemes\" content=\"dark\" /\u003e\r\n    \u003ctitle\u003e{{ if $zh }}确认订阅 ZPass 早期通知{{ else }}Confirm your ZPass subscription{{ end }}\u003c/title\u003e\r\n    \u003cstyle\u003e\r\n      :root { color-scheme: dark; }\r\n      body { margin: 0 !important; padding: 0 !important; background: #0c0c0d !important; }\r\n      a { text-decoration: none; }\r\n      @media (max-width: 620px) {\r\n        .zp-shell { width: 100% !important; padding: 24px 16px !important; }\r\n        .zp-card  { padding: 28px 20px !important; border-radius: 10px !important; }\r\n        .zp-h1    { font-size: 22px !important; line-height: 1.3 !important; }\r\n        .zp-cta   { width: 100% !important; box-sizing: border-box !important; }\r\n        .zp-link-fallback { font-size: 11px !important; }\r\n      }\r\n      @media (prefers-color-scheme: dark) {\r\n        .zp-bg   { background: #0c0c0d !important; }\r\n        .zp-card { background: #111113 !important; }\r\n        .zp-text { color: #ececec !important; }\r\n        .zp-mute { color: #a8a8ac !important; }\r\n      }\r\n    \u003c/style\u003e\r\n  \u003c/head\u003e\r\n  \u003cbody\r\n    class=\"zp-bg\"\r\n    style=\"margin:0;padding:0;background:#0c0c0d;font-family:'Geist',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue','PingFang SC','Hiragino Sans GB','Microsoft YaHei',Arial,sans-serif;color:#ececec;-webkit-font-smoothing:antialiased;\"\r\n  \u003e\r\n    \u003c!-- 预览文字 --\u003e\r\n    \u003cdiv\r\n      style=\"display:none;max-height:0;overflow:hidden;mso-hide:all;font-size:1px;line-height:1px;color:#0c0c0d;opacity:0;\"\r\n    \u003e\r\n      {{ if $zh }}还差一步——请确认你的邮箱以完成 ZPass 发布通知订阅。{{ else }}One last step — confirm your email to finish subscribing to ZPass release updates.{{ end }}\r\n    \u003c/div\u003e\r\n\r\n    \u003ctable\r\n      role=\"presentation\"\r\n      width=\"100%\"\r\n      cellpadding=\"0\"\r\n      cellspacing=\"0\"\r\n      border=\"0\"\r\n      style=\"background:#0c0c0d;\"\r\n    \u003e\r\n      \u003ctr\u003e\r\n        \u003ctd align=\"center\" style=\"padding:48px 16px;\"\u003e\r\n          \u003ctable\r\n            role=\"presentation\"\r\n            class=\"zp-shell\"\r\n            width=\"600\"\r\n            cellpadding=\"0\"\r\n            cellspacing=\"0\"\r\n            border=\"0\"\r\n            style=\"width:600px;max-width:600px;\"\r\n          \u003e\r\n            \u003c!-- ===== 品牌头 ===== --\u003e\r\n            \u003ctr\u003e\r\n              \u003ctd style=\"padding:0 4px 20px 4px;\"\u003e\r\n                \u003ctable role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"\u003e\r\n                  \u003ctr\u003e\r\n                    \u003ctd align=\"left\" style=\"vertical-align:middle;\"\u003e\r\n                      \u003cspan\r\n                        style=\"display:inline-block;width:22px;height:22px;background:#d4ff3a;border-radius:5px;vertical-align:middle;\"\r\n                      \u003e\u003c/span\u003e\r\n                      \u003cspan\r\n                        style=\"display:inline-block;margin-left:10px;font-size:15px;font-weight:600;letter-spacing:-0.01em;color:#ececec;vertical-align:middle;\"\r\n                        class=\"zp-text\"\r\n                        \u003eZPass\u003c/span\r\n                      \u003e\r\n                    \u003c/td\u003e\r\n                    \u003ctd\r\n                      align=\"right\"\r\n                      style=\"vertical-align:middle;font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:11px;letter-spacing:0.08em;color:#6e6e73;text-transform:uppercase;\"\r\n                    \u003e\r\n                      {{ if $zh }}抢先体验{{ else }}EARLY ACCESS{{ end }}\r\n                    \u003c/td\u003e\r\n                  \u003c/tr\u003e\r\n                \u003c/table\u003e\r\n              \u003c/td\u003e\r\n            \u003c/tr\u003e\r\n\r\n            \u003c!-- ===== 主卡片 ===== --\u003e\r\n            \u003ctr\u003e\r\n              \u003ctd\r\n                class=\"zp-card\"\r\n                style=\"background:#111113;border:1px solid #232328;border-radius:10px;padding:40px 40px 36px 40px;\"\r\n              \u003e\r\n                \u003c!-- eyebrow --\u003e\r\n                \u003cp\r\n                  style=\"margin:0 0 18px 0;font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:11px;letter-spacing:0.12em;color:#6e6e73;text-transform:uppercase;\"\r\n                \u003e\r\n                  {{ if $zh }}01 · 确认邮箱{{ else }}01 · Confirm email{{ end }}\r\n                \u003c/p\u003e\r\n\r\n                \u003c!-- 标题 --\u003e\r\n                \u003ch1\r\n                  class=\"zp-h1 zp-text\"\r\n                  style=\"margin:0 0 14px 0;font-family:'Geist',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'PingFang SC','Hiragino Sans GB','Microsoft YaHei',sans-serif;font-size:26px;line-height:1.25;font-weight:600;letter-spacing:-0.02em;color:#ececec;\"\r\n                \u003e\r\n                  {{ if $zh }}还差一步，即可加入 ZPass 候补名单。{{ else }}One last step to join the ZPass waitlist.{{ end }}\r\n                \u003c/h1\u003e\r\n\r\n                \u003c!-- 正文 --\u003e\r\n                \u003cp\r\n                  class=\"zp-mute\"\r\n                  style=\"margin:0 0 28px 0;font-size:14px;line-height:1.6;color:#a8a8ac;\"\r\n                \u003e\r\n                  {{ if $zh -}}\r\n                  我们收到了来自\r\n                  \u003cspan style=\"color:#ececec;font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;\"\u003e{{ .Subscriber.Email }}\u003c/span\u003e\r\n                  的订阅申请。点击下方按钮确认这确实是你——ZPass 发布时我们会第一时间告知你，除此之外不会发任何邮件。\r\n                  {{- else -}}\r\n                  We received a subscription request for\r\n                  \u003cspan style=\"color:#ececec;font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;\"\u003e{{ .Subscriber.Email }}\u003c/span\u003e.\r\n                  Tap the button below to confirm it's really you — we'll only email you when ZPass ships. No marketing, ever.\r\n                  {{- end }}\r\n                \u003c/p\u003e\r\n\r\n                \u003c!-- CTA --\u003e\r\n                \u003ctable role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"margin:0 0 28px 0;\"\u003e\r\n                  \u003ctr\u003e\r\n                    \u003ctd\r\n                      align=\"center\"\r\n                      style=\"border-radius:7px;background:#d4ff3a;\"\r\n                    \u003e\r\n                      \u003ca\r\n                        href=\"{{ .Tx.Data.optin_url }}\"\r\n                        class=\"zp-cta\"\r\n                        target=\"_blank\"\r\n                        style=\"display:inline-block;padding:13px 26px;font-family:'Geist',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'PingFang SC','Hiragino Sans GB','Microsoft YaHei',sans-serif;font-size:14px;font-weight:600;letter-spacing:-0.01em;color:#0c0c0d;background:#d4ff3a;border-radius:7px;text-decoration:none;\"\r\n                        \u003e{{ if $zh }}确认订阅\u0026nbsp;→{{ else }}Confirm subscription\u0026nbsp;→{{ end }}\u003c/a\r\n                      \u003e\r\n                    \u003c/td\u003e\r\n                  \u003c/tr\u003e\r\n                \u003c/table\u003e\r\n\r\n                \u003c!-- 分隔线 --\u003e\r\n                \u003chr\r\n                  style=\"margin:28px 0;border:none;border-top:1px solid #232328;height:0;\"\r\n                /\u003e\r\n\r\n                \u003c!-- 可复制链接 fallback --\u003e\r\n                \u003cp\r\n                  style=\"margin:0 0 8px 0;font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:11px;letter-spacing:0.08em;color:#6e6e73;text-transform:uppercase;\"\r\n                \u003e\r\n                  {{ if $zh }}按钮无法点击？{{ else }}Button not working?{{ end }}\r\n                \u003c/p\u003e\r\n                \u003cp\r\n                  class=\"zp-link-fallback\"\r\n                  style=\"margin:0;font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:12px;line-height:1.6;color:#a8a8ac;word-break:break-all;\"\r\n                \u003e\r\n                  \u003ca href=\"{{ .Tx.Data.optin_url }}\" style=\"color:#d4ff3a;text-decoration:none;\"\u003e{{ .Tx.Data.optin_url }}\u003c/a\u003e\r\n                \u003c/p\u003e\r\n              \u003c/td\u003e\r\n            \u003c/tr\u003e\r\n\r\n            \u003c!-- ===== 说明条 ===== --\u003e\r\n            \u003ctr\u003e\r\n              \u003ctd style=\"padding:20px 4px 0 4px;\"\u003e\r\n                \u003cp\r\n                  class=\"zp-mute\"\r\n                  style=\"margin:0;font-size:12px;line-height:1.6;color:#6e6e73;\"\r\n                \u003e\r\n                  {{ if $zh }}如果这不是你发起的订阅，可以安全忽略本邮件——我们不会再联系你。{{ else }}If you didn't request this, you can safely ignore this email — we won't contact you again.{{ end }}\r\n                \u003c/p\u003e\r\n              \u003c/td\u003e\r\n            \u003c/tr\u003e\r\n\r\n            \u003c!-- ===== 页脚 ===== --\u003e\r\n            \u003ctr\u003e\r\n              \u003ctd style=\"padding:28px 4px 0 4px;\"\u003e\r\n                \u003ctable role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"\u003e\r\n                  \u003ctr\u003e\r\n                    \u003ctd\r\n                      align=\"left\"\r\n                      style=\"font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:11px;letter-spacing:0.04em;color:#45454a;\"\r\n                    \u003e\r\n                      {{ if $zh }}© 2026 ZPass · 端到端加密的密码管理器{{ else }}© 2026 ZPass · End-to-end encrypted password manager{{ end }}\r\n                    \u003c/td\u003e\r\n                    \u003ctd\r\n                      align=\"right\"\r\n                      style=\"font-family:'Geist Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:11px;color:#45454a;\"\r\n                    \u003e\r\n                      {{ if .Tx.Data.unsub_url }}\u003ca href=\"{{ .Tx.Data.unsub_url }}\" style=\"color:#6e6e73;text-decoration:none;\"\u003e{{ if $zh }}退订{{ else }}Unsubscribe{{ end }}\u003c/a\u003e{{ end }}\r\n                    \u003c/td\u003e\r\n                  \u003c/tr\u003e\r\n                \u003c/table\u003e\r\n              \u003c/td\u003e\r\n            \u003c/tr\u003e\r\n          \u003c/table\u003e\r\n        \u003c/td\u003e\r\n      \u003c/tr\u003e\r\n    \u003c/table\u003e\r\n  \u003c/body\u003e\r\n\u003c/html\u003e\r\n","body_source":null,"is_default":false}}
