---
// ============================================================================
// ZPass 官网 — 中文首页（zh locale）
// 路径：/zh/
// 依次渲染 Nav → Hero → Subscribe → Features → How → Live → Mobile →
//        Security → Pricing → Changelog → FAQ → Footer。
// 文案来自 src/i18n/strings.ts 中的 `zh` 集合。
//
// 注：前期开发期版本——
//   - 用 Subscribe(邮件订阅) 区块替代原 Install(curl 安装命令) 区块
//   - Live(实时演示 iframe) 默认 show=false 隐藏,产品尚未发布
//   - 页面 SEO 描述去掉了"开源 / 自托管"等表述
// ============================================================================

import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Hero from "../../components/Hero.astro";
import Subscribe from "../../components/Subscribe.astro";
import Features from "../../components/Features.astro";
import How from "../../components/How.astro";
import Live from "../../components/Live.astro";
import Desktop from "../../components/Desktop.astro";
import Mobile from "../../components/Mobile.astro";
import Security from "../../components/Security.astro";
import Pricing from "../../components/Pricing.astro";
import Changelog from "../../components/Changelog.astro";
import Faq from "../../components/Faq.astro";
import Footer from "../../components/Footer.astro";
import ContactDialog from "../../components/ContactDialog.astro";
import { getStrings } from "../../i18n/strings";

const locale = "zh" as const;
const t = getStrings(locale);

const pageTitle = "ZPass — 一款不打扰你的密码管理器";
const pageDesc =
	"ZPass 是一款基于零知识架构的跨平台密码管理器。端到端加密、零知识——目前正在紧张研发中。订阅邮箱,发布时第一时间通知你。macOS · Windows · Linux · iOS · Android · 浏览器扩展。";
---

<BaseLayout
	title={pageTitle}
	description={pageDesc}
	locale={locale}
	theme="auto"
	body="sans"
>
	<Nav t={t} locale={locale} />

	<main>
		<Hero t={t} locale={locale} />
		<Subscribe t={t} />
		<Features t={t} />
		<How t={t} />
		<Live t={t} />
		<Desktop t={t} />
		<Mobile t={t} />
		<Security t={t} />
		<Pricing t={t} />
		<Changelog t={t} />
		<Faq t={t} />
	</main>

	<Footer t={t} />
	<ContactDialog t={t} />
</BaseLayout>
