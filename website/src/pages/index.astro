---
// ============================================================================
// ZPass 官网 — 英文首页 (默认语言)
// 路径：/  （由 Astro i18n 配置 prefixDefaultLocale: false 决定）
// 组合所有章节组件，传入 EN 文案。
//
// 注：发布前版本——
//   - 用 Release(“即将发布” 状态区块) 替代原 Subscribe(邮件订阅) 区块
//   - Live(实时演示 iframe) 默认 show=false 隐藏,产品尚未发布
// ============================================================================

import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Release from "../components/Release.astro";
import Features from "../components/Features.astro";
import How from "../components/How.astro";
import Live from "../components/Live.astro";
import Desktop from "../components/Desktop.astro";
import Mobile from "../components/Mobile.astro";
import Security from "../components/Security.astro";
import Changelog from "../components/Changelog.astro";
import Pricing from "../components/Pricing.astro";
import Faq from "../components/Faq.astro";
import Footer from "../components/Footer.astro";
import ContactDialog from "../components/ContactDialog.astro";

import { applyVersion, getStrings } from "../i18n/strings";
import { getLatestRelease } from "../lib/release-fetcher";
import { getPricingTiers } from "../lib/pricing-fetcher";

// 走 SSR：每次请求都通过 release-fetcher 取最新版本（命中 24h 缓存时无外网开销），
// 用拿到的版本号把所有 `{version}` 占位符替换成真实值，再交给子组件渲染。
export const prerender = false;

const locale = "en" as const;
const release = await getLatestRelease();
const t = applyVersion(getStrings(locale), release.version);
// 套餐档与运营平台同源（公开端点拉取，失败降级内置文案）。
const pricingTiers = await getPricingTiers(locale, t);

// 页面级 SEO
const title = "ZPass — a calmer password manager";
const description =
	"ZPass is an open-source, cross-platform credential manager built on zero-knowledge architecture. End-to-end encrypted, self-hostable, AGPL-3.0 — launching soon.";
---

<BaseLayout
	title={title}
	description={description}
	locale={locale}
	theme="auto"
	body="sans"
>
	<Nav t={t} locale={locale} />
	<main>
		<Hero t={t} locale={locale} />
		<Features t={t} />
		<How t={t} variant="soft" />
		<Live t={t} />
		<Desktop t={t} variant="ink" />
		<Mobile t={t} />
		<Release t={t} locale={locale} variant="soft" />
		<Security t={t} variant="ink" />
		<Pricing t={t} tiers={pricingTiers} />
		<Changelog t={t} variant="soft" />
		<Faq t={t} />
	</main>
	<Footer t={t} locale={locale} />
	<ContactDialog t={t} />
</BaseLayout>
