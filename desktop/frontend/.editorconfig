# EditorConfig — https://editorconfig.org
# 与 ZPassDesign / website 项目保持一致：tab 缩进、LF 换行、UTF-8

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 2

[*.{json,jsonc,md,yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
