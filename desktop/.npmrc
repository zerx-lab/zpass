# Electron Forge requires a flat node_modules layout. Without hoisting,
# Forge refuses to package because Electron's packager cannot find
# dependencies through pnpm's symlinked store.
node-linker=hoisted

# Download Electron binaries from the npmmirror CDN; the default GitHub
# release host frequently times out in mainland China.
electron_mirror=https://npmmirror.com/mirrors/electron/
