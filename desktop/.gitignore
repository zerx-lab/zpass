electron/src/api/schema.ts

# macOS app icon — generated by `task icns` on darwin runners only. Not worth
# committing the binary blob since iconutil isn't cross-platform anyway.
assets/logo/zpass.icns
assets/logo/zpass.iconset/

# OS junk
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
