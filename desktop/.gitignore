# Node / Electron
node_modules/
.vite/
out/

# Dev hot-restart trigger written by scripts/dev-watcher.mjs; watched by Electron main
.dev-reload

# Go
bin/

# Taskfile local build cache
.task/

# Generated artifacts (regenerated by `task codegen` / `task openapi`).
